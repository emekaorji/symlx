{
  "name": "symlx",
  "version": "0.1.12",
  "description": "Temporary local CLI bin linker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emekaorji/symlx.git"
  },
  "homepage": "https://github.com/emekaorji/symlx#readme",
  "bugs": {
    "url": "https://github.com/emekaorji/symlx/issues"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "symlx": "dist/cli.js",
    "cx": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && tsc -p tsconfig.test.json && node --test .tmp-tests/test/**/*.test.js",
    "preinstall": "node dist/preinstall.js",
    "postinstall": "node dist/postinstall.js",
    "prepack": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "cli",
    "bin",
    "command-linker",
    "local-cli",
    "developer-tooling",
    "symlink",
    "typescript",
    "nodejs",
    "npm-link"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "zod": "^4.3.6"
  }
}
